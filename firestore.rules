rules_version = '2';

// ===============================================================
// Assumed Data Model
// ===============================================================
//
// Collection: users
// Document ID: Firebase Auth UID
// Fields:
//   - email: string (required) - user email
//   - displayName: string (required, max 100) - display name
//   - photoURL: string (optional) - avatar URL
//   - language: string (required) - 'en' | 'hi'
//   - consentGiven: bool (required, immutable) - DPDP consent
//   - createdAt: timestamp (required, immutable)
//
// Collection: profiles
// Document ID: auto-generated
// Fields:
//   - uid: string (required, immutable) - owner Firebase UID
//   - name: string (required, max 60) - person's name
//   - dob: string (required) - YYYY-MM-DD
//   - tob: string (required) - HH:MM
//   - birthCity: string (required, max 100)
//   - lat: number (required, -90 to 90)
//   - lng: number (required, -180 to 180)
//   - timezone: string (required)
//   - isDefault: bool (required)
//   - avatarUrl: string (optional)
//   - createdAt: timestamp (required, immutable)
//   - updatedAt: timestamp (required)
//
// Collection: kundlis
// Document ID: profileId
// Fields:
//   - uid: string (required, immutable) - owner Firebase UID
//   - profileId: string (required, immutable)
//   - ayanamsha: string (required) - 'LAHIRI'|'RAMAN'|'KRISHNAMURTI'|'TRUE_CHITRA'
//   - data: map (required) - calculation result blob
//   - shareToken: string (required) - for public sharing
//   - isPublic: bool (required)
//   - createdAt: timestamp (required, immutable)
//   - updatedAt: timestamp (required)
//
// Collection: milans
// Document ID: auto-generated
// Fields:
//   - uid: string (required, immutable) - owner Firebase UID
//   - profile1Id: string (required, immutable)
//   - profile2Id: string (required, immutable)
//   - data: map (required) - compatibility result blob
//   - createdAt: timestamp (required, immutable)
//
// ===============================================================

service cloud.firestore {
  match /databases/{database}/documents {

    // ---------------------------------------------------------------
    // Helper Functions
    // ---------------------------------------------------------------

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isAuthenticated() && request.auth.uid == uid;
    }

    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.uid;
    }

    function uidUnchanged() {
      return request.resource.data.uid == request.auth.uid;
    }

    function uidNotModified() {
      return request.resource.data.uid == resource.data.uid;
    }

    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    function areImmutableFieldsUnchanged(fields) {
      return !request.resource.data.diff(resource.data).affectedKeys().hasAny(fields);
    }

    function isRecent(time) {
      return time is timestamp &&
             time > request.time - duration.value(5, 'm') &&
             time <= request.time;
    }

    function isValidUrl(url) {
      return url is string &&
        (url.matches("^https://.*") || url.matches("^http://.*"));
    }

    // ---------------------------------------------------------------
    // Domain Validators
    // ---------------------------------------------------------------

    function isValidUser(data) {
      return hasOnlyAllowedFields(['email', 'displayName', 'photoURL', 'language', 'consentGiven', 'createdAt']) &&
             data.email is string && data.email.size() > 0 && data.email.size() < 255 &&
             data.displayName is string && data.displayName.size() > 0 && data.displayName.size() <= 100 &&
             (!('photoURL' in data) || (data.photoURL is string && isValidUrl(data.photoURL) && data.photoURL.size() < 500)) &&
             data.language is string && data.language in ['en', 'hi'] &&
             data.consentGiven is bool &&
             data.createdAt is timestamp;
    }

    function isValidUserUpdate(data) {
      return hasOnlyAllowedFields(['displayName', 'photoURL', 'language']) &&
             (!('displayName' in data) || (data.displayName is string && data.displayName.size() > 0 && data.displayName.size() <= 100)) &&
             (!('photoURL' in data) || (data.photoURL is string && isValidUrl(data.photoURL) && data.photoURL.size() < 500)) &&
             (!('language' in data) || (data.language is string && data.language in ['en', 'hi']));
    }

    function isValidProfile(data) {
      return hasOnlyAllowedFields(['uid', 'name', 'dob', 'tob', 'birthCity', 'lat', 'lng', 'timezone', 'isDefault', 'avatarUrl', 'createdAt', 'updatedAt']) &&
             data.uid is string && data.uid.size() > 0 && data.uid.size() <= 128 &&
             data.name is string && data.name.size() >= 2 && data.name.size() <= 60 &&
             data.dob is string && data.dob.matches("^\\d{4}-\\d{2}-\\d{2}$") &&
             data.tob is string && data.tob.matches("^\\d{2}:\\d{2}$") &&
             data.birthCity is string && data.birthCity.size() >= 1 && data.birthCity.size() <= 100 &&
             data.lat is number && data.lat >= -90 && data.lat <= 90 &&
             data.lng is number && data.lng >= -180 && data.lng <= 180 &&
             data.timezone is string && data.timezone.size() >= 1 && data.timezone.size() <= 60 &&
             data.isDefault is bool &&
             (!('avatarUrl' in data) || (data.avatarUrl is string && isValidUrl(data.avatarUrl) && data.avatarUrl.size() < 500)) &&
             data.createdAt is timestamp &&
             data.updatedAt is timestamp;
    }

    function isValidProfileUpdate(data) {
      return hasOnlyAllowedFields(['name', 'dob', 'tob', 'birthCity', 'lat', 'lng', 'timezone', 'isDefault', 'avatarUrl', 'updatedAt']) &&
             (!('name' in data) || (data.name is string && data.name.size() >= 2 && data.name.size() <= 60)) &&
             (!('dob' in data) || (data.dob is string && data.dob.matches("^\\d{4}-\\d{2}-\\d{2}$"))) &&
             (!('tob' in data) || (data.tob is string && data.tob.matches("^\\d{2}:\\d{2}$"))) &&
             (!('birthCity' in data) || (data.birthCity is string && data.birthCity.size() >= 1 && data.birthCity.size() <= 100)) &&
             (!('lat' in data) || (data.lat is number && data.lat >= -90 && data.lat <= 90)) &&
             (!('lng' in data) || (data.lng is number && data.lng >= -180 && data.lng <= 180)) &&
             (!('timezone' in data) || (data.timezone is string && data.timezone.size() >= 1 && data.timezone.size() <= 60)) &&
             (!('isDefault' in data) || data.isDefault is bool) &&
             (!('avatarUrl' in data) || (data.avatarUrl is string && isValidUrl(data.avatarUrl) && data.avatarUrl.size() < 500)) &&
             data.updatedAt is timestamp;
    }

    function isValidAyanamsha(a) {
      return a is string && a in ['LAHIRI', 'RAMAN', 'KRISHNAMURTI', 'TRUE_CHITRA'];
    }

    function isValidKundli(data) {
      return hasOnlyAllowedFields(['uid', 'profileId', 'ayanamsha', 'data', 'shareToken', 'isPublic', 'createdAt', 'updatedAt']) &&
             data.uid is string && data.uid.size() > 0 && data.uid.size() <= 128 &&
             data.profileId is string && data.profileId.size() > 0 &&
             isValidAyanamsha(data.ayanamsha) &&
             data.data is map &&
             data.shareToken is string && data.shareToken.size() > 0 && data.shareToken.size() <= 64 &&
             data.isPublic is bool &&
             data.createdAt is timestamp &&
             data.updatedAt is timestamp;
    }

    function isValidKundliUpdate(data) {
      return hasOnlyAllowedFields(['ayanamsha', 'data', 'shareToken', 'isPublic', 'updatedAt']) &&
             (!('ayanamsha' in data) || isValidAyanamsha(data.ayanamsha)) &&
             (!('data' in data) || data.data is map) &&
             (!('shareToken' in data) || (data.shareToken is string && data.shareToken.size() > 0 && data.shareToken.size() <= 64)) &&
             (!('isPublic' in data) || data.isPublic is bool) &&
             data.updatedAt is timestamp;
    }

    function isValidMilan(data) {
      return hasOnlyAllowedFields(['uid', 'profile1Id', 'profile2Id', 'data', 'createdAt']) &&
             data.uid is string && data.uid.size() > 0 && data.uid.size() <= 128 &&
             data.profile1Id is string && data.profile1Id.size() > 0 &&
             data.profile2Id is string && data.profile2Id.size() > 0 &&
             data.data is map &&
             data.createdAt is timestamp;
    }

    // ---------------------------------------------------------------
    // users/{uid}
    // ---------------------------------------------------------------
    match /users/{uid} {
      allow read: if isOwner(uid);
      allow create: if isOwner(uid) &&
                       isValidUser(request.resource.data) &&
                       uidUnchanged() &&
                       isRecent(request.resource.data.createdAt);
      allow update: if isOwner(uid) &&
                       isValidUserUpdate(request.resource.data) &&
                       areImmutableFieldsUnchanged(['email', 'consentGiven', 'createdAt']);
      allow delete: if isOwner(uid);
    }

    // ---------------------------------------------------------------
    // profiles/{profileId}
    // ---------------------------------------------------------------
    match /profiles/{profileId} {
      allow read: if isAuthenticated() && isDocOwner();
      allow create: if isAuthenticated() &&
                       uidUnchanged() &&
                       isValidProfile(request.resource.data) &&
                       isRecent(request.resource.data.createdAt);
      allow update: if isDocOwner() &&
                       isValidProfileUpdate(request.resource.data) &&
                       areImmutableFieldsUnchanged(['uid', 'createdAt']);
      allow delete: if isDocOwner();
    }

    // ---------------------------------------------------------------
    // kundlis/{kundliId}
    // Public kundlis are readable by anyone (share feature).
    // Only the owner can write.
    // ---------------------------------------------------------------
    match /kundlis/{kundliId} {
      allow read: if resource.data.isPublic == true ||
                     (isAuthenticated() && resource.data.uid == request.auth.uid);
      allow create: if isAuthenticated() &&
                       uidUnchanged() &&
                       isValidKundli(request.resource.data) &&
                       isRecent(request.resource.data.createdAt);
      allow update: if isDocOwner() &&
                       isValidKundliUpdate(request.resource.data) &&
                       areImmutableFieldsUnchanged(['uid', 'profileId', 'createdAt']);
      allow delete: if isDocOwner();
    }

    // ---------------------------------------------------------------
    // milans/{milanId}
    // ---------------------------------------------------------------
    match /milans/{milanId} {
      allow read: if isAuthenticated() && isDocOwner();
      allow create: if isAuthenticated() &&
                       uidUnchanged() &&
                       isValidMilan(request.resource.data) &&
                       isRecent(request.resource.data.createdAt);
      allow delete: if isDocOwner();
    }

    // Deny everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
